{
	"name": "hekas-app",
	"private": true,
	"version": "0.1.0",
	"description": "HEKAS POS — Frontend (SvelteKit 2 + Svelte 5 + Tailwind 4)",
	"type": "module",
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0",
		"npm": ">=10.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:component": "vitest run --config vitest-svelte.config.ts",
		"test:component:watch": "vitest --config vitest-svelte.config.ts",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:all": "vitest run && vitest run --config vitest-svelte.config.ts && playwright test",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint . || echo 'eslint not configured yet'",
		"hooks:install": "bash ../scripts/hooks/install.sh",
		"hooks:uninstall": "rm -f ../../.git/hooks/pre-commit ../../.git/hooks/commit-msg ../../.git/hooks/pre-push"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"prettier --check"
		],
		"*.{json,css,yml,yaml}": [
			"prettier --check"
		]
	},
	"devDependencies": {
		"@playwright/test": "^1.49.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.0",
		"@vitest/coverage-v8": "^2.1.0",
		"jsdom": "^25.0.0",
		"lint-staged": "^17.0.8",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2"
	}
}
